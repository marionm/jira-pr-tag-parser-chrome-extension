{
  "manifest_version": 3,

  "name": "Jira PR tag parser",
  "description": "Turns Jira tags in PR titles into links",
  "version": "4.0",

  "background": {
    "service_worker": "background.js"
  },

  "options_page": "options.html",

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "https://www.github.com/buildoutinc/*",
    "https://github.com/buildoutinc/*"
  ]
}
